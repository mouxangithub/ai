{
  "version": 2,
  "plugins": [
    {
      "id": "core-extensions",
      "name": "op助手核心扩展",
      "description": "系统控制、Git、审计、网络诊断等内置扩展工具",
      "module": "ai.plugins.builtin.core",
      "enabled": true
    },
    {
      "id": "device-extras",
      "name": "设备健康插件",
      "description": "device_health / panda_status",
      "module": "ai.plugins.builtin.device_extras",
      "enabled": true
    },
    {
      "id": "github-ci",
      "name": "GitHub CI",
      "description": "Workflow 触发/等待/重跑、Runner 健康检查",
      "module": "ai.plugins.builtin.github_ci",
      "enabled": true
    },
    {
      "id": "branch-ota",
      "name": "Prebuilt / OTA",
      "description": "prebuilt 分支状态、切换、OTA 预检",
      "module": "ai.plugins.builtin.branch_ota",
      "enabled": true
    },
    {
      "id": "tsk-secoc",
      "name": "TSK SecOC",
      "description": "TSK 结构化失败诊断",
      "module": "ai.plugins.builtin.tsk_secoc",
      "enabled": true
    },
    {
      "id": "sunnylink-cloud",
      "name": "Sunnylink 云",
      "description": "备份/恢复进度监视",
      "module": "ai.plugins.builtin.sunnylink_cloud",
      "enabled": true
    },
    {
      "id": "route-analytics",
      "name": "路线分析",
      "description": "路线评分与批量对比工具分组",
      "module": "ai.plugins.builtin.route_analytics",
      "enabled": true
    },
    {
      "id": "vehicle-adaptation",
      "name": "车辆适配",
      "description": "新车适配工具分组",
      "module": "ai.plugins.builtin.vehicle_adaptation",
      "enabled": true
    },
    {
      "id": "git-github",
      "name": "Git / Pull Request",
      "description": "本地改代码 → 提交推送 → 创建/审阅/合并 PR",
      "module": "ai.plugins.builtin.git_github",
      "enabled": true
    }
  ]
}
